local function scanForGunDrops()
    clearAllGunESP()
    for _,obj in pairs(workspace:GetDescendants()) do
        if obj.Name=="GunDrop" and obj:IsA("BasePart") and not belongsToAnyPlayer(obj) then createGunESP(obj) end
    end
