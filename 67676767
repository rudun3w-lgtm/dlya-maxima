local ROLE_COLORS = {
    Murderer=Color3.fromRGB(255,50,50), Sheriff=Color3.fromRGB(50,120,255),
    Hero=Color3.fromRGB(50,120,255), Innocent=Color3.fromRGB(50,255,50),
    Dead=Color3.fromRGB(180,180,180), Lobby=Color3.fromRGB(180,180,180)
}
local deadPlayers, roleCache = {}, {}

local function getPlayerRole(player)
    local char = player.Character
    if not char then return "Lobby" end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return "Dead" end
    if hum.Health <= 0 then deadPlayers[player]=true; roleCache[player]="Dead"; return "Dead" end
    if deadPlayers[player] then deadPlayers[player]=nil end
    local bp = player:FindFirstChild("Backpack")
    local function hasToolIn(c,n)
        if not c then return false end
        for _,i in pairs(c:GetChildren()) do
            if i:IsA("Tool") and i.Name:lower()==n:lower() then return true end
        end
        return false
    end
    if hasToolIn(bp,"Knife") or hasToolIn(char,"Knife") then roleCache[player]="Murderer"; return "Murderer" end
    if hasToolIn(bp,"Gun") or hasToolIn(char,"Gun") or hasToolIn(bp,"Revolver") or hasToolIn(char,"Revolver") then roleCache[player]="Sheriff"; return "Sheriff" end
    roleCache[player]="Innocent"; return "Innocent"
end

local function monitorBackpack(player)
    local function onBackpack(bp)
        if not bp then return end
        bp.ChildAdded:Connect(function(c) if c:IsA("Tool") then roleCache[player]=nil end end)
        bp.ChildRemoved:Connect(function(c) if c:IsA("Tool") then roleCache[player]=nil end end)
    end
    local bp=player:FindFirstChild("Backpack"); if bp then onBackpack(bp) end
    player.ChildAdded:Connect(function(c) if c.Name=="Backpack" then onBackpack(c) end end)
end

local function onNewRound() for p in pairs(deadPlayers) do deadPlayers[p]=nil end; roleCache={} end

for _,p in pairs(Players:GetPlayers()) do monitorBackpack(p); p.CharacterAdded:Connect(function() deadPlayers[p]=nil; roleCache[p]=nil end) end
LocalPlayer.CharacterAdded:Connect(function() onNewRound() end)
Players.PlayerAdded:Connect(function(p) monitorBackpack(p); p.CharacterAdded:Connect(function() deadPlayers[p]=nil; roleCache[p]=nil end) end)

local function findClosestByRole(rf)
    local cl,cd=nil,math.huge; local mc=LocalPlayer.Character
    if not mc or not mc:FindFirstChild("HumanoidRootPart") then return nil end
    local mp=mc.HumanoidRootPart.Position
    for _,p in pairs(Players:GetPlayers()) do
        if p~=LocalPlayer then
            local r=getPlayerRole(p); local v=false
            if rf=="All" then v=(r~="Dead" and r~="Lobby")
            elseif rf=="Innocent" then v=(r=="Innocent")
            elseif rf=="Sheriff" then v=(r=="Sheriff" or r=="Hero")
            elseif rf=="Murderer" then v=(r=="Murderer") end
            if v then local ch=p.Character; if ch and ch:FindFirstChild("HumanoidRootPart") then
                local h=ch:FindFirstChildOfClass("Humanoid")
                if h and h.Health>0 then local d=(ch.HumanoidRootPart.Position-mp).Magnitude; if d<cd then cd=d;cl=p end end
            end end
        end
    end; return cl
end

