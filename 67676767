local function updateESP(player)
	local d=espObjects[player]; if not d then return end
	local role=getPlayerRole(player); local color=ROLE_COLORS[role] or ROLE_COLORS.Innocent
	if role=="Murderer" then d.roleLabel.Text="🔪 "..L("murderer")
	elseif role=="Sheriff" then d.roleLabel.Text="🔫 "..L("sheriff")
	elseif role=="Hero" then d.roleLabel.Text="🔫 "..L("hero")
	elseif role=="Innocent" then d.roleLabel.Text="🟢 "..L("innocent")
	elseif role=="Dead" then d.roleLabel.Text="💀 "..L("dead")
	else d.roleLabel.Text="⚪ "..L("lobby") end
	d.roleLabel.TextColor3=color; d.nameLabel.TextColor3=color
	local char=player.Character; local ok=char and char:FindFirstChild("Head") and char:FindFirstChild("HumanoidRootPart")
	if not ok then d.billboard.Parent=nil; d.nameBillboard.Parent=nil; d.highlight.Parent=nil; if d.tracer then d.tracer.Visible=false end; return end
	if Settings.espEnabled then d.highlight.Parent=char; d.highlight.FillColor=color; d.highlight.OutlineColor=color else d.highlight.Parent=nil end
	if Settings.rolesEnabled then d.billboard.Adornee=char.Head; d.billboard.Parent=game:GetService("CoreGui") else d.billboard.Parent=nil end
	if Settings.namesEnabled then d.nameBillboard.Adornee=char.Head; d.nameBillboard.Parent=game:GetService("CoreGui") else d.nameBillboard.Parent=nil end
	if Settings.tracersEnabled and d.tracer then
		local sp,on=Camera:WorldToViewportPoint(char.HumanoidRootPart.Position)
		if on then d.tracer.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y); d.tracer.To=Vector2.new(sp.X,sp.Y); d.tracer.Color=color; d.tracer.Visible=true
		else d.tracer.Visible=false end
	elseif d.tracer then d.tracer.Visible=false end
end

local function removeESP(player)
	local d=espObjects[player]; if not d then return end
	pcall(function() d.billboard:Destroy() end); pcall(function() d.nameBillboard:Destroy() end); pcall(function() d.highlight:Destroy() end)
	if d.tracer then pcall(function() d.tracer:Remove() end) end; espObjects[player]=nil
end

