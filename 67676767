local function updateGunESP()
    if not Settings.gunEspEnabled then return end
    local myChar=LocalPlayer.Character; local myPos=nil
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then myPos=myChar.HumanoidRootPart.Position end
    for part,data in pairs(gunEspObjects) do
        if not part or not part.Parent then removeGunESP(part)
        else if myPos then
            local ok,pos=pcall(function() return part.Position end)
            if ok and pos then local dist=math.floor((myPos-pos).Magnitude); data.label.Text="🔫 GUN ["..dist.."m]" end
        end end
    end
end

