RS.Heartbeat:Connect(function(dt)
	for player in pairs(espObjs) do
		if player and player.Parent then updateESP(player) else removeESP(player) end
	end
	updateGunESP()
	if rgbSky and S.skyEnabled and colorCorrection then
		skyColor=Color3.fromHSV(tick()*0.15%1,0.8,1)
		pcall(function() colorCorrection.TintColor=skyColor end)
	end
	if rgbAll then
		local h=tick()*0.35%1
		accentColor=Color3.fromHSV(h,1,1); bgColor=Color3.fromHSV((h+0.5)%1,0.5,0.15); updateColors()
	elseif rgbAccent then
		accentColor=Color3.fromHSV(tick()*0.35%1,1,1); updateColors()
	elseif rgbBg then
		bgColor=Color3.fromHSV(tick()*0.25%1,0.5,0.15); updateColors()
	end
	if Main.Visible then updateParts(dt) end
	if S.aimMurdererEnabled and (aimMurdActive or aimMurdRMB) then doAim(findClosest("Murderer")) end
	if S.aimSheriffEnabled  and (aimSherActive or aimSherRMB)  then doAim(findClosest("Sheriff"))  end
	if S.aimInnocentEnabled and (aimInnActive  or aimInnRMB)  then doAim(findClosest("Innocent")) end
	if S.aimAllEnabled      and (aimAllActive  or aimAllRMB)  then doAim(findClosest("All"))      end
	if S.fovValue~=70 then Cam.FieldOfView=S.fovValue end
end)

