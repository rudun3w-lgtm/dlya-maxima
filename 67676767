local function doResetSettings()
	accentColor=Color3.fromRGB(200,30,30); bgColor=Color3.fromRGB(12,12,18); skyColor=Color3.fromRGB(100,180,255)
	rgbAccent=false; rgbBg=false; rgbAll=false; rgbSky=false
	for _,k in pairs({"rgbAccent","rgbBg","rgbAll","rgbSky"}) do
		if toggleRefs[k] then toggleRefs[k].set(false) end
	end
	skySatVal=0.4; skyContrastVal=0.15; skyBrightVal=0.05
	if sliderRefs.skySat     then sliderRefs.skySat.setValue(0.4) end
	if sliderRefs.skyContrast then sliderRefs.skyContrast.setValue(0.15) end
	if sliderRefs.skyBright   then sliderRefs.skyBright.setValue(0.05) end
	if toggleRefs.skyToggle and toggleRefs.skyToggle.get() then
		S.skyEnabled=false; removeSky(); toggleRefs.skyToggle.set(false)
	end
	if toggleRefs.leaves then toggleRefs.leaves.set(false) end
	if toggleRefs.snow   then toggleRefs.snow.set(false) end
	clearParts(); currentUIStyle=1; applyUIStyle(1)
	currentLang="EN"; updateLanguage(); updateColors(); autoSave()
end

local function doResetVisual()
	for _,k in pairs({"esp","names","tracers","roles"}) do
		if toggleRefs[k] then toggleRefs[k].set(false) end
	end
	if toggleRefs.gunEsp then toggleRefs.gunEsp.set(false); clearGunESP() end
	for _,d in pairs(espObjs) do
		pcall(function() d.hl.Parent=nil end)
		pcall(function() d.bb.Parent=nil end)
		pcall(function() d.nb.Parent=nil end)
		if d.tr then pcall(function() d.tr.Visible=false end) end
	end
	autoSave()
end

