	knob.Size=UDim2.new(0,16,0,16); knob.Position=UDim2.new(pct,-8,0.5,-8)
	knob.BackgroundColor3=Color3.fromRGB(255,255,255); knob.BorderSizePixel=0; knob.ZIndex=8
	Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
	local ks=Instance.new("UIStroke",knob); ks.Color=accentColor; ks.Thickness=2
	table.insert(accentEls,{ks,"Color"})
	local curV=defV
	local function updVis(v)
		curV=v; local p=(v-minV)/(maxV-minV)
		sFill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-8,0.5,-8)
		vLbl.Text=string.format("%.2f",v)
	end
	local function updMouse(mx)
		local bp=sBG.AbsolutePosition.X; local bs=sBG.AbsoluteSize.X
		local p=math.clamp((mx-bp)/bs,0,1)
		local v=minV+(maxV-minV)*p; v=math.floor(v*100)/100
		updVis(v); onChange(v)
	end
	sBG.MouseButton1Down:Connect(function()
		isSliding=true; isDrag=false; updMouse(Mouse.X)
		local mc,uc
		mc=Mouse.Move:Connect(function() if isSliding then updMouse(Mouse.X) end end)
		uc=UIS.InputEnded:Connect(function(inp)
			if inp.UserInputType==Enum.UserInputType.MouseButton1 then
				isSliding=false; autoSave()
				if mc then mc:Disconnect() end
				if uc then uc:Disconnect() end
			end
		end)
	end)
	local ref={
		frame=fr, label=lbl, valLbl=vLbl,
		setValue=function(v) updVis(v); onChange(v) end,
		getValue=function() return curV end,
		updateLang=function() lbl.Text=L(labelKey) end,
	}
	sliderRefs[refKey]=ref
	return ref
end

