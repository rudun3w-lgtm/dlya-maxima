        valLbl.Text=string.format("%.2f",v)
    end
    local function updateFromMouse(mouseX)
        local bgPos=sliderBG.AbsolutePosition.X; local bgSize=sliderBG.AbsoluteSize.X
        local pos=math.clamp((mouseX-bgPos)/bgSize,0,1)
        local value=minVal+(maxVal-minVal)*pos; value=math.floor(value*100)/100
        updateVisual(value); onChange(value)
    end
    sliderBG.MouseButton1Down:Connect(function()
        sliding=true; dragging=false; updateFromMouse(Mouse.X)
        local mc,uc
        mc=Mouse.Move:Connect(function() if sliding then updateFromMouse(Mouse.X) end end)
        uc=UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                sliding=false; autoSave()
                if mc then mc:Disconnect() end; if uc then uc:Disconnect() end
            end
        end)
    end)
    local ref={frame=frame,label=lbl,valLabel=valLbl,
        setValue=function(v) updateVisual(v); onChange(v) end,
        getValue=function() return currentVal end,
        updateLang=function() lbl.Text=L(labelKey) end,defaultVal=defaultVal}
    settingsSliderRefs[refKey]=ref; return ref
end

