    Instance.new("UICorner",sliderBG).CornerRadius=UDim.new(0,6)
    local fillPct=(defaultVal-minVal)/(maxVal-minVal)
    local sliderFill=Instance.new("Frame",sliderBG); sliderFill.Size=UDim2.new(fillPct,0,1,0); sliderFill.BackgroundColor3=accentColor; sliderFill.BorderSizePixel=0; sliderFill.ZIndex=7
    Instance.new("UICorner",sliderFill).CornerRadius=UDim.new(0,6); table.insert(accentElements,{sliderFill,"BackgroundColor3"})
    local knob=Instance.new("Frame",sliderBG); knob.Size=UDim2.new(0,16,0,16); knob.Position=UDim2.new(fillPct,-8,0.5,-8)
