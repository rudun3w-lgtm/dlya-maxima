task.defer(function()
	local d=loadSave()
	if not d then print("Riflis Hub — no save, using defaults"); return end

	local function trSet(k,v) if toggleRefs[k] then toggleRefs[k].set(v) end end

	if d.accentColor then local c=t2c(d.accentColor); if c then accentColor=c end end
	if d.bgColor     then local c=t2c(d.bgColor);     if c then bgColor=c end end
	if d.skyColor    then local c=t2c(d.skyColor);    if c then skyColor=c end end

	if d.skySatVal     then skySatVal=d.skySatVal;         if sliderRefs.skySat      then sliderRefs.skySat.setValue(d.skySatVal) end end
	if d.skyContrastVal then skyContrastVal=d.skyContrastVal; if sliderRefs.skyContrast then sliderRefs.skyContrast.setValue(d.skyContrastVal) end end
	if d.skyBrightVal  then skyBrightVal=d.skyBrightVal;   if sliderRefs.skyBright   then sliderRefs.skyBright.setValue(d.skyBrightVal) end end

	if d.rgbAccent~=nil then rgbAccent=d.rgbAccent; trSet("rgbAccent",d.rgbAccent) end
	if d.rgbBg~=nil     then rgbBg=d.rgbBg;         trSet("rgbBg",d.rgbBg) end
	if d.rgbAll~=nil    then rgbAll=d.rgbAll;        trSet("rgbAll",d.rgbAll) end
	if d.rgbSky~=nil    then rgbSky=d.rgbSky;        trSet("rgbSky",d.rgbSky) end

	if d.lang     then currentLang=d.lang; updateLanguage() end
	if d.uiStyle  then currentUIStyle=d.uiStyle; applyUIStyle(currentUIStyle) end

	if d.espEnabled~=nil     then trSet("esp",d.espEnabled) end
	if d.namesEnabled~=nil   then trSet("names",d.namesEnabled) end
	if d.tracersEnabled~=nil then trSet("tracers",d.tracersEnabled) end
	if d.rolesEnabled~=nil   then trSet("roles",d.rolesEnabled) end
	if d.gunEspEnabled~=nil  then trSet("gunEsp",d.gunEspEnabled) end
	if d.skyEnabled~=nil     then trSet("skyToggle",d.skyEnabled) end
	if d.leavesEnabled~=nil  then trSet("leaves",d.leavesEnabled) end
	if d.snowEnabled~=nil    then trSet("snow",d.snowEnabled) end

	if d.aimMurdererEnabled~=nil   then S.aimMurdererEnabled=d.aimMurdererEnabled;     trSet("aimMurderer",d.aimMurdererEnabled) end
	if d.aimMurdererBtnVisible~=nil then S.aimMurdererBtnVisible=d.aimMurdererBtnVisible; trSet("aimMurdererBtn",d.aimMurdererBtnVisible); AimMBtn.Visible=d.aimMurdererBtnVisible end
	if d.aimSheriffEnabled~=nil    then S.aimSheriffEnabled=d.aimSheriffEnabled;       trSet("aimSheriff",d.aimSheriffEnabled) end
	if d.aimSheriffBtnVisible~=nil  then S.aimSheriffBtnVisible=d.aimSheriffBtnVisible;   trSet("aimSheriffBtn",d.aimSheriffBtnVisible); AimSBtn.Visible=d.aimSheriffBtnVisible end
	if d.aimInnocentEnabled~=nil   then S.aimInnocentEnabled=d.aimInnocentEnabled;     trSet("aimInnocent",d.aimInnocentEnabled) end
	if d.aimInnocentBtnVisible~=nil then S.aimInnocentBtnVisible=d.aimInnocentBtnVisible; trSet("aimInnocentBtn",d.aimInnocentBtnVisible); AimIBtn.Visible=d.aimInnocentBtnVisible end
	if d.aimAllEnabled~=nil        then S.aimAllEnabled=d.aimAllEnabled;               trSet("aimAll",d.aimAllEnabled) end
	if d.aimAllBtnVisible~=nil      then S.aimAllBtnVisible=d.aimAllBtnVisible;           trSet("aimAllBtn",d.aimAllBtnVisible); AimABtn.Visible=d.aimAllBtnVisible end

	if d.aimMurdererRMBOn~=nil then trSet("aimMurdererRMB",d.aimMurdererRMBOn) end
	if d.aimSheriffRMBOn~=nil  then trSet("aimSheriffRMB",d.aimSheriffRMBOn)  end
	if d.aimInnocentRMBOn~=nil then trSet("aimInnocentRMB",d.aimInnocentRMBOn) end
	if d.aimAllRMBOn~=nil      then trSet("aimAllRMB",d.aimAllRMBOn)           end

	if d.stretchRatio~=nil and stretchSlider then
		S.stretchRatio=d.stretchRatio
		getgenv()._RiflisStretch.value=d.stretchRatio
		stretchSlider.setValue(d.stretchRatio)
	end
