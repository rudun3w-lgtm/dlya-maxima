local stretchSlider, fovSlider

do
	local function mkSlider(parent,yS,secK,prefK,minV,maxV,defV,isInt,rKey,pKey,pVal,rVal,onChange)
		local secLbl=mkSecLabel(parent,yS,L(secK))
		local valLbl=Instance.new("TextLabel",parent)
		valLbl.Size=UDim2.new(1,-20,0,25); valLbl.Position=UDim2.new(0,10,0,yS+25)
