local function walkfling()
	walkflinging=true
	task.spawn(function()
		local movel=0.1
		while walkflinging do
			RS.Heartbeat:Wait()
			local c=LP.Character; local r=getRoot(c)
			if r then
				local vel=r.Velocity
				r.Velocity=vel*8000+Vector3.new(0,8000,0)
				RS.RenderStepped:Wait()
				if r.Parent then r.Velocity=vel end
				RS.Stepped:Wait()
				if r.Parent then r.Velocity=vel+Vector3.new(0,movel,0) end
				movel=-movel
			end
		end
	end)
end
local function unwalkfling() walkflinging=false end

local function antifling()
	if antiflingConn then antiflingConn:Disconnect(); antiflingConn=nil end
	antiflingConn=RS.Stepped:Connect(function()
		local mc=LP.Character; local mr=getRoot(mc)
		if not mr then return end
		for _,p in pairs(Players:GetPlayers()) do
			if p~=LP and p.Character then
				local r=getRoot(p.Character)
				if r and (r.Position-mr.Position).Magnitude<25 then
					for _,v in pairs(p.Character:GetDescendants()) do
						if v:IsA("BasePart") then v.CanCollide=false end
					end
				end
			end
		end
	end)
end
local function unantifling()
	if antiflingConn then antiflingConn:Disconnect(); antiflingConn=nil end
end

local function unfling()
	flinging=false
	if flingDied then flingDied:Disconnect(); flingDied=nil end
	local c=LP.Character
	if c then
		for _,v in pairs(c:GetDescendants()) do
			if v:IsA("BodyAngularVelocity") or v:IsA("BodyThrust") or v:IsA("BodyVelocity") then
				v:Destroy()
			end
		end
	end
	noclipOff()
end

local function fling()
	local c=getChar(); local r=getRoot(c); local h=getHum(c)
	if not c or not r or not h then return end
	unfling(); noclipOn(); flinging=true
	for _,v in pairs(c:GetDescendants()) do
		if v:IsA("BasePart") then
			pcall(function() v.CustomPhysicalProperties=PhysicalProperties.new(100,0.3,0.5) end)
			v.CanCollide=false; v.Massless=true; v.Velocity=Vector3.new(0,0,0)
		end
	end
	local bav=Instance.new("BodyAngularVelocity")
	bav.Name="FlingBV"; bav.Parent=r
	bav.AngularVelocity=Vector3.new(0,99999,0)
	bav.MaxTorque=Vector3.new(0,math.huge,0); bav.P=math.huge
	flingDied=h.Died:Connect(function() unfling() end)
	task.spawn(function()
		while flinging and bav.Parent do
			bav.AngularVelocity=Vector3.new(0,99999,0); task.wait(0.2)
			if not flinging or not bav.Parent then break end
			bav.AngularVelocity=Vector3.new(0,0,0); task.wait(0.1)
		end
		if bav and bav.Parent then bav:Destroy() end
	end)
end

