local function spawnPart(isSnow)
	local vW,vH=Cam.ViewportSize.X,Cam.ViewportSize.Y
	local ch=isSnow and SNOW_C or LEAF_C
	local p=Instance.new("TextLabel",partFolder)
	p.Size=UDim2.new(0,30,0,30); p.BackgroundTransparency=1
	p.Text=ch[math.random(1,#ch)]
	p.TextSize=isSnow and math.random(12,22) or math.random(16,28)
	p.Font=Enum.Font.GothamBold; p.TextColor3=Color3.fromRGB(255,255,255); p.ZIndex=1
	local sX=math.random(0,math.floor(vW)); local eX=sX+math.random(-100,100)
	local dur=isSnow and math.random(30,60)/10 or math.random(25,50)/10
	local sR=math.random(0,360)
	p.Position=UDim2.new(0,sX,0,-40); p.Rotation=sR
	local tw=TS:Create(p,TweenInfo.new(dur,Enum.EasingStyle.Linear),
		{Position=UDim2.new(0,eX,0,vH+50),Rotation=sR+math.random(-360,360)})
	tw:Play(); table.insert(activeParts,p)
	tw.Completed:Connect(function()
		pcall(function() p:Destroy() end)
		for i,v in pairs(activeParts) do if v==p then table.remove(activeParts,i) break end end
	end)
end

