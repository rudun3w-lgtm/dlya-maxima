    local rowStroke=Instance.new("UIStroke",row)
    rowStroke.Color=Color3.fromRGB(38,38,50); rowStroke.Thickness=1

    local titleLbl=Instance.new("TextLabel",row)
    titleLbl.Size=UDim2.new(1,-60,0,22)
    titleLbl.Position=UDim2.new(0,12,0,descText and 8 or 10)
    titleLbl.BackgroundTransparency=1
    titleLbl.Text=titleText
    titleLbl.TextColor3=Color3.fromRGB(220,220,220)
    titleLbl.TextSize=13
    titleLbl.Font=Enum.Font.GothamBold
    titleLbl.TextXAlignment=Enum.TextXAlignment.Left
    titleLbl.ZIndex=6

    if descText then
        local descLbl=Instance.new("TextLabel",row)
        descLbl.Size=UDim2.new(1,-60,0,18)
        descLbl.Position=UDim2.new(0,12,0,28)
        descLbl.BackgroundTransparency=1
        descLbl.Text=descText
        descLbl.TextColor3=Color3.fromRGB(100,100,115)
        descLbl.TextSize=10
        descLbl.Font=Enum.Font.Gotham
        descLbl.TextXAlignment=Enum.TextXAlignment.Left
        descLbl.ZIndex=6
    end

    -- Toggle switch (pill style)
    local togW,togH=38,20
    local togBG=Instance.new("Frame",row)
    togBG.Size=UDim2.new(0,togW,0,togH)
    togBG.Position=UDim2.new(1,-togW-10,0.5,-togH/2)
    togBG.BackgroundColor3=defaultVal and accentColor or Color3.fromRGB(45,45,58)
    togBG.BorderSizePixel=0; togBG.ZIndex=7
    Instance.new("UICorner",togBG).CornerRadius=UDim.new(1,0)

    local knob=Instance.new("Frame",togBG)
    knob.Size=UDim2.new(0,14,0,14)
    knob.Position=defaultVal and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
    knob.BackgroundColor3=Color3.fromRGB(255,255,255)
    knob.BorderSizePixel=0; knob.ZIndex=8
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)

    local enabled=defaultVal
    local clickBtn=Instance.new("TextButton",row)
    clickBtn.Size=UDim2.new(1,0,1,0)
    clickBtn.BackgroundTransparency=1
    clickBtn.Text=""; clickBtn.ZIndex=9

    local function setVal(v)
        enabled=v
        TweenService:Create(togBG,tweenFast,{BackgroundColor3=v and accentColor or Color3.fromRGB(45,45,58)}):Play()
        TweenService:Create(knob,tweenFast,{Position=v and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)}):Play()
        onToggle(v)
    end
    clickBtn.MouseButton1Click:Connect(function() setVal(not enabled); autoSave() end)
    row.MouseEnter:Connect(function() TweenService:Create(rowStroke,tweenFast,{Color=accentColor}):Play() end)
    row.MouseLeave:Connect(function() TweenService:Create(rowStroke,tweenFast,{Color=Color3.fromRGB(38,38,50)}):Play() end)

    return {frame=row,set=setVal,get=function() return enabled end,
        togBG=togBG,knob=knob,titleLbl=titleLbl}
end

