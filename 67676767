local function SkidFling(TP, dur)
	if not TP or not TP.Character then return end
	skidFlingActive=true
	local Char=LP.Character
	local Hum=Char and Char:FindFirstChildOfClass("Humanoid")
	local Root=Hum and Hum.RootPart
	local TC=TP.Character
	if not Char or not Hum or not Root then skidFlingActive=false; return end
	local TH=TC:FindFirstChildOfClass("Humanoid")
	local TR=TH and TH.RootPart
	local THead=TC:FindFirstChild("Head")
	local Acc=TC:FindFirstChildOfClass("Accessory")
	local Handle=Acc and Acc:FindFirstChild("Handle")
	if Root.Velocity.Magnitude<50 then getgenv().OldPos=Root.CFrame end
	local focus=THead or Handle or TR
	if focus then workspace.CurrentCamera.CameraSubject=focus end
	local function FPos(BP, Pos, Ang)
		if not BP or not BP.Parent or not Root.Parent then return end
		tpChar(CFrame.new(BP.Position)*Pos*Ang)
		Root.Velocity=Vector3.new(9e7,9e7*10,9e7)
		Root.RotVelocity=Vector3.new(9e8,9e8,9e8)
	end
	local function SFBase(BP)
		local TW=dur or 2; local T=tick(); local Angle=0
		repeat
			if Root and TH and BP and BP.Parent then
				if BP.Velocity.Magnitude<50 then
					Angle=Angle+100
					FPos(BP,CFrame.new(0,1.5,0)+TH.MoveDirection*BP.Velocity.Magnitude/1.25,CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BP,CFrame.new(0,-1.5,0)+TH.MoveDirection*BP.Velocity.Magnitude/1.25,CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BP,CFrame.new(2.25,1.5,-2.25)+TH.MoveDirection*BP.Velocity.Magnitude/1.25,CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BP,CFrame.new(-2.25,-1.5,2.25)+TH.MoveDirection*BP.Velocity.Magnitude/1.25,CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BP,CFrame.new(0,1.5,0)+TH.MoveDirection,CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BP,CFrame.new(0,-1.5,0)+TH.MoveDirection,CFrame.Angles(math.rad(Angle),0,0)); task.wait()
				else
					FPos(BP,CFrame.new(0,1.5,TH.WalkSpeed),CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BP,CFrame.new(0,-1.5,-TH.WalkSpeed),CFrame.Angles(0,0,0)); task.wait()
					FPos(BP,CFrame.new(0,1.5,TH.WalkSpeed),CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BP,CFrame.new(0,1.5,TR and TR.Velocity.Magnitude/1.25 or 0),CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BP,CFrame.new(0,-1.5,-(TR and TR.Velocity.Magnitude/1.25 or 0)),CFrame.Angles(0,0,0)); task.wait()
					FPos(BP,CFrame.new(0,1.5,TR and TR.Velocity.Magnitude/1.25 or 0),CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BP,CFrame.new(0,-1.5,0),CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BP,CFrame.new(0,-1.5,0),CFrame.Angles(0,0,0)); task.wait()
					FPos(BP,CFrame.new(0,-1.5,0),CFrame.Angles(math.rad(-90),0,0)); task.wait()
					FPos(BP,CFrame.new(0,-1.5,0),CFrame.Angles(0,0,0)); task.wait()
				end
			else break end
		until not skidFlingActive or not BP or not BP.Parent
			or BP.Velocity.Magnitude>500
			or BP.Parent~=TP.Character or TP.Parent~=Players
			or TP.Character~=TC or not TH or TH.Sit
			or tick()>T+TW
	end
	local prevH=workspace.FallenPartsDestroyHeight
	workspace.FallenPartsDestroyHeight=0/0
	local BV=Instance.new("BodyVelocity"); BV.Name="EpixVel"; BV.Parent=Root
	BV.Velocity=Vector3.new(9e8,9e8,9e8)
	BV.MaxForce=Vector3.new(math.huge,math.huge,math.huge)
	pcall(function() Hum:SetStateEnabled(Enum.HumanoidStateType.Seated,false) end)
	if TR and THead then
		if (TR.Position-THead.Position).Magnitude>5 then SFBase(THead) else SFBase(TR) end
	elseif TR then SFBase(TR)
	elseif THead then SFBase(THead)
	elseif Acc and Handle then SFBase(Handle) end
	if BV then BV:Destroy() end
	pcall(function() Hum:SetStateEnabled(Enum.HumanoidStateType.Seated,true) end)
	workspace.CurrentCamera.CameraSubject=Hum
	repeat
		if Char and Hum and Root and getgenv().OldPos then
			tpChar(getgenv().OldPos*CFrame.new(0,0.5,0))
			Hum:ChangeState(Enum.HumanoidStateType.GettingUp)
			for _,x in pairs(Char:GetChildren()) do
				if x:IsA("BasePart") then x.Velocity=Vector3.new(); x.RotVelocity=Vector3.new() end
			end
		end
		task.wait()
	until not skidFlingActive
		or (Root and getgenv().OldPos and (Root.Position-getgenv().OldPos.p).Magnitude<25)
	workspace.FallenPartsDestroyHeight=prevH
	skidFlingActive=false
end

local function findNear(dist)
	local mc=LP.Character; if not mc then return nil end
	local mr=getRoot(mc); if not mr then return nil end
	local best,bd=nil,math.huge
	for _,p in pairs(Players:GetPlayers()) do
		if p~=LP and p.Character then
			local r=getRoot(p.Character); local h=getHum(p.Character)
			if r and h and h.Health>0 then
				local d=(r.Position-mr.Position).Magnitude
				if d<=dist and d<bd then bd=d; best=p end
			end
		end
	end
	return best
end

local function stopFlingLoop()
	if flingLoopConn then flingLoopConn:Disconnect(); flingLoopConn=nil end
	skidFlingActive=false
end
local function startFlingLoop()
	stopFlingLoop()
	flingLoopConn=RS.Heartbeat:Connect(function()
		if not S.flingEnabled or skidFlingActive then return end
		local t=findNear(8); if not t then return end
		noclipOn(); task.spawn(function() SkidFling(t,2); noclipOff() end)
	end)
end

