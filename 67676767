local function createSlider(parent,yStart,sectionKey,prefixKey,minVal,maxVal,defaultVal,isInt,resetKey,presetKey,presetVal,resetVal,onChange)
	local sectionLabel=createSectionLabel(parent,yStart,L(sectionKey))
	local valueLabel=Instance.new("TextLabel",parent); valueLabel.Size=UDim2.new(1,-20,0,25); valueLabel.Position=UDim2.new(0,10,0,yStart+25)
	valueLabel.BackgroundTransparency=1; valueLabel.TextColor3=Color3.fromRGB(255,255,255); valueLabel.TextSize=15; valueLabel.Font=Enum.Font.GothamBold; valueLabel.TextXAlignment=Enum.TextXAlignment.Left; valueLabel.ZIndex=5
	local function formatVal(v) if isInt then return tostring(math.floor(v)) else return string.format("%.2f",v) end end
	valueLabel.Text=L(prefixKey)..formatVal(defaultVal)
	local fillPct=(defaultVal-minVal)/(maxVal-minVal)
	local sliderBG=Instance.new("TextButton",parent); sliderBG.Size=UDim2.new(1,-30,0,18); sliderBG.Position=UDim2.new(0,15,0,yStart+58)
	sliderBG.BackgroundColor3=Color3.fromRGB(40,40,60); sliderBG.BorderSizePixel=0; sliderBG.Text=""; sliderBG.AutoButtonColor=false; sliderBG.ZIndex=6
	Instance.new("UICorner",sliderBG).CornerRadius=UDim.new(0,9)
	local sliderFill=Instance.new("Frame",sliderBG); sliderFill.Size=UDim2.new(fillPct,0,1,0); sliderFill.BackgroundColor3=accentColor; sliderFill.BorderSizePixel=0; sliderFill.ZIndex=7
	Instance.new("UICorner",sliderFill).CornerRadius=UDim.new(0,9); table.insert(accentElements,{sliderFill,"BackgroundColor3"})
	local sliderKnob=Instance.new("Frame",sliderBG); sliderKnob.Size=UDim2.new(0,24,0,24); sliderKnob.Position=UDim2.new(fillPct,-12,0.5,-12)
	sliderKnob.BackgroundColor3=Color3.fromRGB(255,255,255); sliderKnob.BorderSizePixel=0; sliderKnob.ZIndex=8; Instance.new("UICorner",sliderKnob).CornerRadius=UDim.new(1,0)
	local ks=Instance.new("UIStroke",sliderKnob); ks.Color=accentColor; ks.Thickness=3; table.insert(accentElements,{ks,"Color"})
	local currentValue=defaultVal
	local function updateSliderVisual(value)
		currentValue=value; local pos=(value-minVal)/(maxVal-minVal); sliderFill.Size=UDim2.new(pos,0,1,0)
		sliderKnob.Position=UDim2.new(pos,-12,0.5,-12); valueLabel.Text=L(prefixKey)..formatVal(value)
	end
	local function updateFromMouse(mouseX)
		local bgPos=sliderBG.AbsolutePosition.X; local bgSize=sliderBG.AbsoluteSize.X
		local pos=math.clamp((mouseX-bgPos)/bgSize,0,1); local value=minVal+(maxVal-minVal)*pos
		if isInt then value=math.floor(value+0.5) else value=math.floor(value*100)/100 end
		updateSliderVisual(value); onChange(value)
	end
	sliderBG.MouseButton1Down:Connect(function()
		sliding=true; dragging=false; parent.ScrollingEnabled=false; updateFromMouse(Mouse.X)
		local mc,uc
		mc=Mouse.Move:Connect(function() if sliding then updateFromMouse(Mouse.X) end end)
		uc=UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
				sliding=false; parent.ScrollingEnabled=true; autoSave()
				if mc then mc:Disconnect() end; if uc then uc:Disconnect() end end end)
	end)
	local resetBtn=Instance.new("TextButton",parent); resetBtn.Size=UDim2.new(0.46,0,0,36); resetBtn.Position=UDim2.new(0.02,0,0,yStart+88)
	resetBtn.BackgroundColor3=Color3.fromRGB(40,40,60); resetBtn.BorderSizePixel=0; resetBtn.TextColor3=Color3.fromRGB(255,255,255); resetBtn.TextSize=13; resetBtn.Font=Enum.Font.GothamBold; resetBtn.ZIndex=6
	resetBtn.Text=L(resetKey); Instance.new("UICorner",resetBtn).CornerRadius=UDim.new(0,8)
	local presetBtn=Instance.new("TextButton",parent); presetBtn.Size=UDim2.new(0.46,0,0,36); presetBtn.Position=UDim2.new(0.52,0,0,yStart+88)
	presetBtn.BackgroundColor3=accentColor; presetBtn.BorderSizePixel=0; presetBtn.TextColor3=Color3.fromRGB(255,255,255); presetBtn.TextSize=13; presetBtn.Font=Enum.Font.GothamBold; presetBtn.ZIndex=6
	presetBtn.Text=L(presetKey); Instance.new("UICorner",presetBtn).CornerRadius=UDim.new(0,8); table.insert(accentElements,{presetBtn,"BackgroundColor3"})
	resetBtn.MouseButton1Click:Connect(function() updateSliderVisual(resetVal); onChange(resetVal); autoSave() end)
	presetBtn.MouseButton1Click:Connect(function() updateSliderVisual(presetVal); onChange(presetVal); autoSave() end)
	local function setValueExternal(v) v=math.clamp(v,minVal,maxVal); updateSliderVisual(v); onChange(v) end
	return {sectionLabel=sectionLabel,valueLabel=valueLabel,resetBtn=resetBtn,presetBtn=presetBtn,setValue=setValueExternal,
		updateLang=function() sectionLabel.Text=L(sectionKey); resetBtn.Text=L(resetKey); presetBtn.Text=L(presetKey); valueLabel.Text=L(prefixKey)..formatVal(currentValue) end}
end

