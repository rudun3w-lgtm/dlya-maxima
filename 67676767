	Instance.new("UICorner",sBG).CornerRadius=UDim.new(0,6)
	local pct=(defV-minV)/(maxV-minV)
	local sFill=Instance.new("Frame",sBG)
	sFill.Size=UDim2.new(pct,0,1,0); sFill.BackgroundColor3=accentColor
	sFill.BorderSizePixel=0; sFill.ZIndex=7
	Instance.new("UICorner",sFill).CornerRadius=UDim.new(0,6)
