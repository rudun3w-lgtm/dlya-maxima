UIS.InputBegan:Connect(function(inp,gpe)
	if gpe then return end
	if inp.UserInputType==Enum.UserInputType.MouseButton2 then
		if S.aimMurdererEnabled and toggleRefs.aimMurdererRMB and toggleRefs.aimMurdererRMB.get() then aimMurdRMB=true end
		if S.aimSheriffEnabled  and toggleRefs.aimSheriffRMB  and toggleRefs.aimSheriffRMB.get()  then aimSherRMB=true end
		if S.aimInnocentEnabled and toggleRefs.aimInnocentRMB and toggleRefs.aimInnocentRMB.get() then aimInnRMB=true end
		if S.aimAllEnabled      and toggleRefs.aimAllRMB      and toggleRefs.aimAllRMB.get()      then aimAllRMB=true end
	end
	if inp.KeyCode==Enum.KeyCode.P then
		currentLang=currentLang=="EN" and "RU" or "EN"; updateLanguage(); autoSave()
	end
	if inp.KeyCode==Enum.KeyCode.F11 then
		if S.isFullscreen then applyWin() else applyFS() end
	end
	if inp.KeyCode==Enum.KeyCode.L then
		if isAnim then return end
		if MiniBtn.Visible then
			mDragStart=nil; mDragging=false
			local bx,by=MiniBtn.AbsolutePosition.X,MiniBtn.AbsolutePosition.Y
			MiniBtn.Visible=false
			Main.Size=UDim2.new(0,48,0,48); Main.Position=UDim2.new(0,bx,0,by)
			Main.BackgroundTransparency=0.3; Main.Visible=true; isAnim=true
			local tw=TS:Create(Main,tSlow,{
				Size=UDim2.new(0,NSIZE.w,0,NSIZE.h),
				Position=UDim2.new(0,math.max(bx-226,10),0,math.max(by-176,10)),
				BackgroundTransparency=0
			})
			tw:Play(); tw.Completed:Connect(function() isAnim=false end)
		else
			if Main.Visible then Main.Visible=false; clearParts() else Main.Visible=true end
		end
	end
end)

UIS.InputEnded:Connect(function(inp)
	if inp.UserInputType==Enum.UserInputType.MouseButton1 then
		isDrag=false; isSliding=false; mDragStart=nil; mDragging=false
		for _,ct in pairs(allTabC) do ct.ScrollingEnabled=true end
	end
	if inp.UserInputType==Enum.UserInputType.MouseButton2 then
		aimMurdRMB=false; aimSherRMB=false; aimInnRMB=false; aimAllRMB=false
	end
end)

UIS.InputChanged:Connect(function(inp)
	if inp.UserInputType==Enum.UserInputType.MouseMovement then
		if isDrag and not isSliding and not S.isFullscreen then
			Main.Position=UDim2.new(0,inp.Position.X-dragOX,0,inp.Position.Y-dragOY)
			nPos=Main.Position
		end
		if mDragging and mDragPos and MiniBtn.Visible then
			local d=Vector2.new(inp.Position.X,inp.Position.Y)-mDragPos
			if d.Magnitude>8 then
				MiniBtn.Position=UDim2.new(0,inp.Position.X-24,0,inp.Position.Y-24)
			end
		end
	end
end)

Cam:GetPropertyChangedSignal("ViewportSize"):Connect(function()
