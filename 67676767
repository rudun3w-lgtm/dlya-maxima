local function unfling()
	flinging = false
	if flingDied then flingDied:Disconnect(); flingDied = nil end
	local char = LocalPlayer.Character
	if char then
		for _, v in pairs(char:GetDescendants()) do
			if v:IsA("BodyAngularVelocity") or v:IsA("BodyThrust") or v:IsA("BodyVelocity") then
				v:Destroy()
			end
		end
	end
	noclipOff()
end

local function fling()
	local char = getChar()
	local root = getRoot(char)
	local hum = getHumanoid(char)
	if not char or not root or not hum then return end

	unfling()
	noclipOn()
	flinging = true

	for _, child in pairs(char:GetDescendants()) do
		if child:IsA("BasePart") then
			child.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
		end
	end

	for _, v in pairs(char:GetDescendants()) do
		if v:IsA("BasePart") then
			v.CanCollide = false
			v.Massless = true
			v.Velocity = Vector3.new(0, 0, 0)
		end
	end

	local bav = Instance.new("BodyAngularVelocity")
	bav.Name = "FlingBV"
	bav.Parent = root
	bav.AngularVelocity = Vector3.new(0, 99999, 0)
	bav.MaxTorque = Vector3.new(0, math.huge, 0)
	bav.P = math.huge

	if flingDied then flingDied:Disconnect(); flingDied = nil end
	flingDied = hum.Died:Connect(function() unfling() end)

	task.spawn(function()
		while flinging and bav.Parent do
			bav.AngularVelocity = Vector3.new(0, 99999, 0)
			task.wait(0.2)
			if not flinging or not bav.Parent then break end
			bav.AngularVelocity = Vector3.new(0, 0, 0)
			task.wait(0.1)
		end
		if bav and bav.Parent then bav:Destroy() end
	end)
end

local function SkidFling(TargetPlayer, duration)
	if not TargetPlayer or not TargetPlayer.Character then return end
	skidFlingActive = true

	local Character = LocalPlayer.Character
	local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
	local RootPart = Humanoid and Humanoid.RootPart
	local TCharacter = TargetPlayer.Character
	local THumanoid, TRootPart, THead, Accessory, Handle

	if not Character or not Humanoid or not RootPart then
		skidFlingActive = false
		return
	end

	if TCharacter:FindFirstChildOfClass("Humanoid") then
		THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
	end
	if THumanoid and THumanoid.RootPart then TRootPart = THumanoid.RootPart end
	if TCharacter:FindFirstChild("Head") then THead = TCharacter.Head end
	if TCharacter:FindFirstChildOfClass("Accessory") then Accessory = TCharacter:FindFirstChildOfClass("Accessory") end
	if Accessory and Accessory:FindFirstChild("Handle") then Handle = Accessory.Handle end

	if RootPart.Velocity.Magnitude < 50 then
		getgenv().OldPos = RootPart.CFrame
	end

	local focusPart = THead or Handle or TRootPart
	if focusPart then workspace.CurrentCamera.CameraSubject = focusPart end

	local function FPos(BasePart, Pos, Ang)
		if not BasePart or not BasePart.Parent or not RootPart.Parent then return end
		teleportChar(CFrame.new(BasePart.Position) * Pos * Ang)
		RootPart.Velocity = Vector3.new(9e7, 9e7*10, 9e7)
		RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
	end

	local function SFBasePart(BasePart)
		local TimeToWait = duration or 2
		local Time = tick()
		local Angle = 0
		repeat
			if RootPart and THumanoid and BasePart and BasePart.Parent then
				if BasePart.Velocity.Magnitude < 50 then
					Angle = Angle + 100
					FPos(BasePart, CFrame.new(0,1.5,0) + THumanoid.MoveDirection*BasePart.Velocity.Magnitude/1.25, CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,-1.5,0) + THumanoid.MoveDirection*BasePart.Velocity.Magnitude/1.25, CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BasePart, CFrame.new(2.25,1.5,-2.25) + THumanoid.MoveDirection*BasePart.Velocity.Magnitude/1.25, CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BasePart, CFrame.new(-2.25,-1.5,2.25) + THumanoid.MoveDirection*BasePart.Velocity.Magnitude/1.25, CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,1.5,0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle),0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,-1.5,0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle),0,0)); task.wait()
				else
					FPos(BasePart, CFrame.new(0,1.5,THumanoid.WalkSpeed), CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,-1.5,-THumanoid.WalkSpeed), CFrame.Angles(0,0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,1.5,THumanoid.WalkSpeed), CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,1.5, TRootPart and TRootPart.Velocity.Magnitude/1.25 or 0), CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,-1.5,-(TRootPart and TRootPart.Velocity.Magnitude/1.25 or 0)), CFrame.Angles(0,0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,1.5, TRootPart and TRootPart.Velocity.Magnitude/1.25 or 0), CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,-1.5,0), CFrame.Angles(math.rad(90),0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,-1.5,0), CFrame.Angles(0,0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,-1.5,0), CFrame.Angles(math.rad(-90),0,0)); task.wait()
					FPos(BasePart, CFrame.new(0,-1.5,0), CFrame.Angles(0,0,0)); task.wait()
				end
			else break end
		until not skidFlingActive
			or not BasePart or not BasePart.Parent
			or BasePart.Velocity.Magnitude > 500
			or BasePart.Parent ~= TargetPlayer.Character
			or TargetPlayer.Parent ~= Players
			or TargetPlayer.Character ~= TCharacter
			or not THumanoid or THumanoid.Sit
			or tick() > Time + TimeToWait
	end

	local previousDestroyHeight = workspace.FallenPartsDestroyHeight
	workspace.FallenPartsDestroyHeight = 0/0

	local BV = Instance.new("BodyVelocity")
	BV.Name = "EpixVel"; BV.Parent = RootPart
	BV.Velocity = Vector3.new(9e8, 9e8, 9e8)
	BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)

	pcall(function() Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false) end)

	if TRootPart and THead then
		if (TRootPart.Position - THead.Position).Magnitude > 5 then SFBasePart(THead)
		else SFBasePart(TRootPart) end
	elseif TRootPart and not THead then SFBasePart(TRootPart)
	elseif not TRootPart and THead then SFBasePart(THead)
	elseif not TRootPart and not THead and Accessory and Handle then SFBasePart(Handle) end

	if BV then BV:Destroy() end
	pcall(function() Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true) end)
	workspace.CurrentCamera.CameraSubject = Humanoid

	repeat
		if Character and Humanoid and RootPart and getgenv().OldPos then
			teleportChar(getgenv().OldPos * CFrame.new(0, 0.5, 0))
			Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
			for _, x in pairs(Character:GetChildren()) do
				if x:IsA("BasePart") then
					x.Velocity = Vector3.new()
					x.RotVelocity = Vector3.new()
				end
			end
		end
		task.wait()
	until not skidFlingActive
		or (RootPart and getgenv().OldPos and (RootPart.Position - getgenv().OldPos.p).Magnitude < 25)

	workspace.FallenPartsDestroyHeight = previousDestroyHeight
	skidFlingActive = false
end

local function findClosestPlayerNear(dist)
	local myChar = LocalPlayer.Character
	if not myChar then return nil end
	local myHRP = getRoot(myChar)
	if not myHRP then return nil end
	local best, bestDist = nil, math.huge
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then
			local tHRP = getRoot(p.Character)
			local hum = getHumanoid(p.Character)
			if tHRP and hum and hum.Health > 0 then
				local d = (tHRP.Position - myHRP.Position).Magnitude
				if d <= dist and d < bestDist then bestDist = d; best = p end
			end
		end
	end
	return best
end

local function stopFlingLoop()
	if flingLoopConn then flingLoopConn:Disconnect(); flingLoopConn = nil end
	skidFlingActive = false
end

local function startFlingLoop()
	stopFlingLoop()
	flingLoopConn = RunService.Heartbeat:Connect(function()
		if not Settings.flingEnabled then return end
		if skidFlingActive then return end
		local target = findClosestPlayerNear(8)
		if not target then return end
		noclipOn()
		task.spawn(function()
			SkidFling(target, 2)
			noclipOff()
		end)
	end)
end

