local gunTpActive=false
local miscGrabLbl=nil

local function belongsToPlayer(obj)
	for _,p in pairs(Players:GetPlayers()) do
		if p.Character then
			local cur=obj.Parent
			for _=1,5 do
				if not cur then break end
				if cur==p.Character or cur==p:FindFirstChild("Backpack") then return true end
				cur=cur.Parent
			end
		end
	end
	return false
end

local function isValidGun(obj)
	if not obj or not obj.Parent then return false end
	if not obj:IsA("BasePart") or obj.Name~="GunDrop" then return false end
	return not belongsToPlayer(obj)
end

local function findGun()
	local mc=LP.Character; if not mc then return nil end
	local hrp=mc:FindFirstChild("HumanoidRootPart"); if not hrp then return nil end
	local best,bd=nil,math.huge
	for _,o in pairs(workspace:GetDescendants()) do
		if isValidGun(o) then
			local d=(o.Position-hrp.Position).Magnitude
			if d<bd then bd=d; best=o end
		end
	end
	return best
end

local function performGrab(lbl)
	if gunTpActive then return end
	local mc=LP.Character; if not mc then return end
	local hrp=mc:FindFirstChild("HumanoidRootPart"); if not hrp then return end
	local gun=findGun()
	if not gun then
		if lbl then pcall(function() lbl.Text="❌ No gun!"; lbl.TextColor3=Color3.fromRGB(255,80,80) end) end
		task.delay(1.5,function() pcall(function() if lbl then lbl.Text="" end end) end)
		return
	end
	gunTpActive=true
	local saved=hrp.CFrame
	hrp.CFrame=CFrame.new(gun.Position+Vector3.new(0,2.5,0))
	RS.Heartbeat:Wait()
	local h2=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
	if h2 then h2.CFrame=saved end
	gunTpActive=false
	if lbl then pcall(function() lbl.Text="✅ Grabbed!"; lbl.TextColor3=Color3.fromRGB(100,255,150) end) end
	task.delay(1.5,function() pcall(function() if lbl then lbl.Text="" end end) end)
end

