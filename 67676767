local function spawnParticle(isSnow)
	local vW,vH=Camera.ViewportSize.X,Camera.ViewportSize.Y
	local ch=isSnow and SNOW_CHARS or LEAF_CHARS
	local p=Instance.new("TextLabel",particlesFolder); p.Size=UDim2.new(0,30,0,30); p.BackgroundTransparency=1
	p.Text=ch[math.random(1,#ch)]; p.TextSize=isSnow and math.random(12,22) or math.random(16,28)
	p.Font=Enum.Font.GothamBold; p.TextColor3=Color3.fromRGB(255,255,255); p.ZIndex=1
	local sX=math.random(0,math.floor(vW)); local eX=sX+math.random(-100,100)
	local dur=isSnow and math.random(30,60)/10 or math.random(25,50)/10; local sR=math.random(0,360)
	p.Position=UDim2.new(0,sX,0,-40); p.Rotation=sR
	local tw=TweenService:Create(p,TweenInfo.new(dur,Enum.EasingStyle.Linear),{Position=UDim2.new(0,eX,0,vH+50),Rotation=sR+math.random(-360,360)})
	tw:Play(); table.insert(activeParticles,p)
	tw.Completed:Connect(function() pcall(function() p:Destroy() end)
		for i,v in pairs(activeParticles) do if v==p then table.remove(activeParticles,i) break end end end)
end
