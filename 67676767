-- ====== SKY SYSTEM ======
local colorCorrection = nil
local skySatVal = 0.4
local skyContrastVal = 0.15
local skyBrightVal = 0.05

local function applySky(color)
	if colorCorrection then pcall(function() colorCorrection:Destroy() end); colorCorrection = nil end
	for _, v in pairs(Lighting:GetChildren()) do
		if v:IsA("ColorCorrectionEffect") and v.Name == "RiflisSkyCC" then pcall(function() v:Destroy() end) end
	end
	local cc = Instance.new("ColorCorrectionEffect")
	cc.Name = "RiflisSkyCC"; cc.TintColor = color
	cc.Saturation = skySatVal; cc.Contrast = skyContrastVal; cc.Brightness = skyBrightVal
	cc.Parent = Lighting; colorCorrection = cc
end

local function removeSky()
	if colorCorrection then pcall(function() colorCorrection:Destroy() end); colorCorrection = nil end
	for _, v in pairs(Lighting:GetChildren()) do
		if v:IsA("ColorCorrectionEffect") and v.Name == "RiflisSkyCC" then pcall(function() v:Destroy() end) end
	end
end

