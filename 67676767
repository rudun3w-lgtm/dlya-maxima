	if input.UserInputType==Enum.UserInputType.MouseButton2 then aimMurdererRMBFlag=false; aimSheriffRMBFlag=false; aimInnocentRMBFlag=false; aimAllRMBFlag=false end
end)

UserInputService.InputChanged:Connect(function(input)
	if input.UserInputType==Enum.UserInputType.MouseMovement then
		if dragging and not sliding and not Settings.isFullscreen then
			Main.Position=UDim2.new(0,input.Position.X-dragOffsetX,0,input.Position.Y-dragOffsetY)
			normalPos = Main.Position
		end
		if miniDragging and miniDragPos and MnB.Visible then
			local delta=Vector2.new(input.Position.X,input.Position.Y)-miniDragPos
			if delta.Magnitude>8 then MnB.Position=UDim2.new(0,input.Position.X-24,0,input.Position.Y-24) end
		end
	end
end)

