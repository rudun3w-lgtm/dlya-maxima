-- ROLES
-- ======================================================
local ROLE_COLORS = {
	Murderer=Color3.fromRGB(255,50,50),
	Sheriff=Color3.fromRGB(50,120,255),
	Hero=Color3.fromRGB(50,120,255),
	Innocent=Color3.fromRGB(50,255,50),
	Dead=Color3.fromRGB(180,180,180),
	Lobby=Color3.fromRGB(180,180,180)
}
local deadPlayers, roleCache = {}, {}

local function getRole(player)
	local c=player.Character; if not c then return "Lobby" end
	local h=c:FindFirstChildOfClass("Humanoid"); if not h then return "Dead" end
	if h.Health<=0 then deadPlayers[player]=true; roleCache[player]="Dead"; return "Dead" end
	deadPlayers[player]=nil
	local bp=player:FindFirstChild("Backpack")
	local function hasTool(cont, name)
		if not cont then return false end
		for _,i in pairs(cont:GetChildren()) do
			if i:IsA("Tool") and i.Name:lower()==name:lower() then return true end
		end
		return false
	end
	if hasTool(bp,"Knife") or hasTool(c,"Knife") then roleCache[player]="Murderer"; return "Murderer" end
	if hasTool(bp,"Gun") or hasTool(c,"Gun") or hasTool(bp,"Revolver") or hasTool(c,"Revolver") then
		roleCache[player]="Sheriff"; return "Sheriff"
	end
	roleCache[player]="Innocent"; return "Innocent"
end

local function monitorBP(player)
	local function onBP(bp)
		if not bp then return end
		bp.ChildAdded:Connect(function(c) if c:IsA("Tool") then roleCache[player]=nil end end)
		bp.ChildRemoved:Connect(function(c) if c:IsA("Tool") then roleCache[player]=nil end end)
	end
	local bp=player:FindFirstChild("Backpack"); if bp then onBP(bp) end
	player.ChildAdded:Connect(function(c) if c.Name=="Backpack" then onBP(c) end end)
end

local function onNewRound()
	for p in pairs(deadPlayers) do deadPlayers[p]=nil end; roleCache={}
end

for _,p in pairs(Players:GetPlayers()) do
	monitorBP(p)
	p.CharacterAdded:Connect(function() deadPlayers[p]=nil; roleCache[p]=nil end)
end
LP.CharacterAdded:Connect(function() onNewRound() end)
Players.PlayerAdded:Connect(function(p)
	monitorBP(p)
	p.CharacterAdded:Connect(function() deadPlayers[p]=nil; roleCache[p]=nil end)
end)

local function findClosest(rf)
	local mc=LP.Character
	if not mc or not mc:FindFirstChild("HumanoidRootPart") then return nil end
	local mp=mc.HumanoidRootPart.Position
	local cl,cd=nil,math.huge
	for _,p in pairs(Players:GetPlayers()) do
		if p~=LP then
			local r=getRole(p); local ok=false
			if rf=="All" then ok=(r~="Dead" and r~="Lobby")
			elseif rf=="Innocent" then ok=(r=="Innocent")
			elseif rf=="Sheriff" then ok=(r=="Sheriff" or r=="Hero")
			elseif rf=="Murderer" then ok=(r=="Murderer") end
			if ok and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local h=p.Character:FindFirstChildOfClass("Humanoid")
				if h and h.Health>0 then
					local d=(p.Character.HumanoidRootPart.Position-mp).Magnitude
					if d<cd then cd=d; cl=p end
				end
			end
		end
	end
	return cl
end

