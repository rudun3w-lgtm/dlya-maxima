RunService.Heartbeat:Connect(function(dt)
    -- ESP update
    for player,_ in pairs(espObjects) do
        if player and player.Parent then updateESP(player) else removeESP(player) end
    end
    updateGunESP()

    -- RGB Sky
    if rgbSky and Settings.skyEnabled and colorCorrection then
        skyColor=Color3.fromHSV(tick()*0.15%1,0.8,1)
        pcall(function() colorCorrection.TintColor=skyColor end)
    end

    -- RGB colors
    if rgbAll then
        local h=tick()*0.35%1
        accentColor=Color3.fromHSV(h,1,1)
        bgColor=Color3.fromHSV((h+0.5)%1,0.5,0.15)
        updateColors()
    elseif rgbAccent then
        accentColor=Color3.fromHSV(tick()*0.35%1,1,1)
        updateColors()
    elseif rgbBg then
        bgColor=Color3.fromHSV(tick()*0.25%1,0.5,0.15)
        updateColors()
    end

    -- Particles
    if Main.Visible or Main2.Visible then
        updateParticles(dt)
    end

    -- Aim
    if Settings.aimMurdererEnabled and (aimMurdererActive or aimMurdererRMBFlag) then
        doAim(findClosestByRole("Murderer"))
    end
    if Settings.aimSheriffEnabled and (aimSheriffActive or aimSheriffRMBFlag) then
        doAim(findClosestByRole("Sheriff"))
    end
    if Settings.aimInnocentEnabled and (aimInnocentActive or aimInnocentRMBFlag) then
        doAim(findClosestByRole("Innocent"))
    end
    if Settings.aimAllEnabled and (aimAllActive or aimAllRMBFlag) then
        doAim(findClosestByRole("All"))
    end

    -- FOV
    if Settings.fovValue ~= 70 then
        Camera.FieldOfView=Settings.fovValue
    end

    -- Style2 drag fix
    if drag2 and not sliding then
        -- handled in InputChanged
    end
end)

