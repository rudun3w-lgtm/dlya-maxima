		valLbl.TextSize=15; valLbl.Font=Enum.Font.GothamBold
		valLbl.TextXAlignment=Enum.TextXAlignment.Left; valLbl.ZIndex=5
		local function fmt(v) return isInt and tostring(math.floor(v)) or string.format("%.2f",v) end
		valLbl.Text=L(prefK)..fmt(defV)
		local pct=(defV-minV)/(maxV-minV)
		local sBG=Instance.new("TextButton",parent)
		sBG.Size=UDim2.new(1,-30,0,18); sBG.Position=UDim2.new(0,15,0,yS+58)
		sBG.BackgroundColor3=Color3.fromRGB(40,40,60); sBG.BorderSizePixel=0
		sBG.Text=""; sBG.AutoButtonColor=false; sBG.ZIndex=6
		Instance.new("UICorner",sBG).CornerRadius=UDim.new(0,9)
		local sFill=Instance.new("Frame",sBG)
		sFill.Size=UDim2.new(pct,0,1,0); sFill.BackgroundColor3=accentColor
		sFill.BorderSizePixel=0; sFill.ZIndex=7
		Instance.new("UICorner",sFill).CornerRadius=UDim.new(0,9)
		table.insert(accentEls,{sFill,"BackgroundColor3"})
		local knob=Instance.new("Frame",sBG)
		knob.Size=UDim2.new(0,24,0,24); knob.Position=UDim2.new(pct,-12,0.5,-12)
		knob.BackgroundColor3=Color3.fromRGB(255,255,255); knob.BorderSizePixel=0; knob.ZIndex=8
		Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
		local ks=Instance.new("UIStroke",knob); ks.Color=accentColor; ks.Thickness=3
		table.insert(accentEls,{ks,"Color"})
		local curV=defV
		local function updVis(v)
			curV=v; local p=(v-minV)/(maxV-minV)
			sFill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-12,0.5,-12)
			valLbl.Text=L(prefK)..fmt(v)
		end
		local function updMouse(mx)
			local bp=sBG.AbsolutePosition.X; local bs=sBG.AbsoluteSize.X
			local p=math.clamp((mx-bp)/bs,0,1)
			local v=minV+(maxV-minV)*p
			v=isInt and math.floor(v+0.5) or math.floor(v*100)/100
			updVis(v); onChange(v)
		end
		sBG.MouseButton1Down:Connect(function()
			isSliding=true; isDrag=false; parent.ScrollingEnabled=false; updMouse(Mouse.X)
			local mc,uc
			mc=Mouse.Move:Connect(function() if isSliding then updMouse(Mouse.X) end end)
			uc=UIS.InputEnded:Connect(function(inp)
				if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
					isSliding=false; parent.ScrollingEnabled=true; autoSave()
					if mc then mc:Disconnect() end
					if uc then uc:Disconnect() end
				end
			end)
		end)
		local rBtn=Instance.new("TextButton",parent)
		rBtn.Size=UDim2.new(0.46,0,0,36); rBtn.Position=UDim2.new(0.02,0,0,yS+88)
		rBtn.BackgroundColor3=Color3.fromRGB(40,40,60); rBtn.BorderSizePixel=0
		rBtn.TextColor3=Color3.fromRGB(255,255,255); rBtn.TextSize=13
		rBtn.Font=Enum.Font.GothamBold; rBtn.ZIndex=6; rBtn.Text=L(rKey)
		Instance.new("UICorner",rBtn).CornerRadius=UDim.new(0,8)
		local pBtn=Instance.new("TextButton",parent)
		pBtn.Size=UDim2.new(0.46,0,0,36); pBtn.Position=UDim2.new(0.52,0,0,yS+88)
		pBtn.BackgroundColor3=accentColor; pBtn.BorderSizePixel=0
		pBtn.TextColor3=Color3.fromRGB(255,255,255); pBtn.TextSize=13
		pBtn.Font=Enum.Font.GothamBold; pBtn.ZIndex=6; pBtn.Text=L(pKey)
		Instance.new("UICorner",pBtn).CornerRadius=UDim.new(0,8)
		table.insert(accentEls,{pBtn,"BackgroundColor3"})
		rBtn.MouseButton1Click:Connect(function() updVis(rVal); onChange(rVal); autoSave() end)
		pBtn.MouseButton1Click:Connect(function() updVis(pVal); onChange(pVal); autoSave() end)
		return {
			secLbl=secLbl, valLbl=valLbl, rBtn=rBtn, pBtn=pBtn,
			setValue=function(v) v=math.clamp(v,minV,maxV); updVis(v); onChange(v) end,
			updateLang=function()
				secLbl.Text=L(secK); rBtn.Text=L(rKey)
				pBtn.Text=L(pKey); valLbl.Text=L(prefK)..fmt(curV)
			end
		}
	end

	stretchSlider=mkSlider(t4,10,"stretchSection","stretchPrefix",0.20,1.00,S.stretchRatio,
		false,"stretchReset","stretchPreset",0.65,1.00,function(v)
