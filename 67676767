	hl.FillColor=GUN_ESP_COLOR; hl.OutlineColor=GUN_ESP_COLOR
	hl.FillTransparency=0.15; hl.OutlineTransparency=0
	hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent=CoreGui
	local bb=Instance.new("BillboardGui"); bb.Name="RiflisGunBB"; bb.Adornee=part
	bb.Size=UDim2.new(0,150,0,40); bb.StudsOffset=Vector3.new(0,4,0)
	bb.AlwaysOnTop=true; bb.MaxDistance=600; bb.Parent=CoreGui
	local bg=Instance.new("Frame",bb); bg.Size=UDim2.new(1,0,1,0)
	bg.BackgroundColor3=Color3.fromRGB(5,15,35); bg.BackgroundTransparency=0.25; bg.BorderSizePixel=0
	Instance.new("UICorner",bg).CornerRadius=UDim.new(0,8)
	local st=Instance.new("UIStroke",bg); st.Color=GUN_ESP_COLOR; st.Thickness=1.5
	local lbl=Instance.new("TextLabel",bg); lbl.Size=UDim2.new(1,0,1,0)
	lbl.BackgroundTransparency=1; lbl.Text="🔫 GUN [?m]"
	lbl.TextColor3=Color3.fromRGB(255,255,255); lbl.TextSize=13
	lbl.Font=Enum.Font.GothamBold
	lbl.TextStrokeTransparency=0.2; lbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
	gunEspObjs[part]={hl=hl,bb=bb,lbl=lbl}
end

local function removeGunESP(part)
	local d=gunEspObjs[part]; if not d then return end
	pcall(function() d.hl:Destroy() end)
	pcall(function() d.bb:Destroy() end)
	gunEspObjs[part]=nil
end

local function clearGunESP()
	for p in pairs(gunEspObjs) do removeGunESP(p) end
	gunEspObjs={}
	for _,v in pairs(CoreGui:GetChildren()) do
		if v.Name=="RiflisGunHL" or v.Name=="RiflisGunBB" then
			pcall(function() v:Destroy() end)
		end
	end
end

local function scanGuns()
	clearGunESP()
	for _,o in pairs(workspace:GetDescendants()) do
		if o.Name=="GunDrop" and o:IsA("BasePart") and not belongsToPlayer(o) then
			createGunESP(o)
		end
	end
end

local function updateGunESP()
	if not S.gunEspEnabled then return end
	local mc=LP.Character
	local mp=mc and mc:FindFirstChild("HumanoidRootPart") and mc.HumanoidRootPart.Position
	for part,data in pairs(gunEspObjs) do
