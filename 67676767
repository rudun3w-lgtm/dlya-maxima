		end)
	mkSecLabel(t4,145,"──────────────────────────")
	fovSlider=mkSlider(t4,175,"fovSection","fovPrefix",30,120,S.fovValue,
		true,"fovReset","fovPreset",120,70,function(v)
			S.fovValue=v; Cam.FieldOfView=v
		end)
end

