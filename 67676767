-- Style2 slider row
local function createS2Slider(parent, yPos, labelText, minV, maxV, defV, isInt, onChange)
    local row=Instance.new("Frame",parent)
    row.Size=UDim2.new(1,-16,0,54)
    row.Position=UDim2.new(0,8,0,yPos)
    row.BackgroundColor3=Color3.fromRGB(22,22,28)
    row.BorderSizePixel=0; row.ZIndex=5
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,7)
    local rs=Instance.new("UIStroke",row); rs.Color=Color3.fromRGB(38,38,50); rs.Thickness=1

    local nameLbl=Instance.new("TextLabel",row)
    nameLbl.Size=UDim2.new(0.6,0,0,20)
    nameLbl.Position=UDim2.new(0,10,0,6)
    nameLbl.BackgroundTransparency=1
    nameLbl.Text=labelText
    nameLbl.TextColor3=Color3.fromRGB(210,210,210)
    nameLbl.TextSize=12; nameLbl.Font=Enum.Font.GothamBold
    nameLbl.TextXAlignment=Enum.TextXAlignment.Left; nameLbl.ZIndex=6

    local valLbl=Instance.new("TextLabel",row)
    valLbl.Size=UDim2.new(0.35,0,0,20)
    valLbl.Position=UDim2.new(0.62,0,0,6)
    valLbl.BackgroundTransparency=1
    valLbl.Text=isInt and tostring(math.floor(defV)) or string.format("%.2f",defV)
    valLbl.TextColor3=accentColor; valLbl.TextSize=12; valLbl.Font=Enum.Font.GothamBold
    valLbl.TextXAlignment=Enum.TextXAlignment.Right; valLbl.ZIndex=6

    local slBG=Instance.new("TextButton",row)
    slBG.Size=UDim2.new(1,-20,0,10)
    slBG.Position=UDim2.new(0,10,0,34)
    slBG.BackgroundColor3=Color3.fromRGB(38,38,52)
    slBG.BorderSizePixel=0; slBG.Text=""; slBG.AutoButtonColor=false; slBG.ZIndex=6
    Instance.new("UICorner",slBG).CornerRadius=UDim.new(0,5)

    local pct=(defV-minV)/(maxV-minV)
    local slFill=Instance.new("Frame",slBG)
    slFill.Size=UDim2.new(pct,0,1,0)
    slFill.BackgroundColor3=accentColor
    slFill.BorderSizePixel=0; slFill.ZIndex=7
    Instance.new("UICorner",slFill).CornerRadius=UDim.new(0,5)

    local slKnob=Instance.new("Frame",slBG)
    slKnob.Size=UDim2.new(0,14,0,14)
    slKnob.Position=UDim2.new(pct,-7,0.5,-7)
    slKnob.BackgroundColor3=Color3.fromRGB(255,255,255)
    slKnob.BorderSizePixel=0; slKnob.ZIndex=8
    Instance.new("UICorner",slKnob).CornerRadius=UDim.new(1,0)
    local ks2=Instance.new("UIStroke",slKnob); ks2.Color=accentColor; ks2.Thickness=2

    local curV=defV
    local function updateVis(v)
        curV=v
        local p2=(v-minV)/(maxV-minV)
        slFill.Size=UDim2.new(p2,0,1,0)
        slKnob.Position=UDim2.new(p2,-7,0.5,-7)
        valLbl.Text=isInt and tostring(math.floor(v)) or string.format("%.2f",v)
    end
    local function fromMouse(mx)
        local bp=slBG.AbsolutePosition.X; local bs2=slBG.AbsoluteSize.X
        local p2=math.clamp((mx-bp)/bs2,0,1)
        local v=minV+(maxV-minV)*p2
        if isInt then v=math.floor(v+0.5) else v=math.floor(v*100)/100 end
        updateVis(v); onChange(v)
    end
    slBG.MouseButton1Down:Connect(function()
        sliding=true; fromMouse(Mouse.X)
        local mc,uc
        mc=Mouse.Move:Connect(function() if sliding then fromMouse(Mouse.X) end end)
        uc=UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                sliding=false; autoSave()
                if mc then mc:Disconnect() end
                if uc then uc:Disconnect() end
            end
        end)
    end)
    row.MouseEnter:Connect(function() TweenService:Create(rs,tweenFast,{Color=accentColor}):Play() end)
    row.MouseLeave:Connect(function() TweenService:Create(rs,tweenFast,{Color=Color3.fromRGB(38,38,50)}):Play() end)
    return {frame=row, setValue=function(v) updateVis(v); onChange(v) end, getValue=function() return curV end,
        slFill=slFill, slKnob=slKnob, valLbl=valLbl, ks2=ks2}
end

