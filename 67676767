UserInputService.InputBegan:Connect(function(input,gpe)
	if gpe then return end
	if input.UserInputType==Enum.UserInputType.MouseButton2 then
		if Settings.aimMurdererEnabled and toggleRefs.aimMurdererRMB and toggleRefs.aimMurdererRMB.get() then aimMurdererRMBFlag=true end
		if Settings.aimSheriffEnabled and toggleRefs.aimSheriffRMB and toggleRefs.aimSheriffRMB.get() then aimSheriffRMBFlag=true end
		if Settings.aimInnocentEnabled and toggleRefs.aimInnocentRMB and toggleRefs.aimInnocentRMB.get() then aimInnocentRMBFlag=true end
		if Settings.aimAllEnabled and toggleRefs.aimAllRMB and toggleRefs.aimAllRMB.get() then aimAllRMBFlag=true end
	end
	if input.KeyCode==Enum.KeyCode.P then currentLang=currentLang=="EN" and "RU" or "EN"; updateLanguage(); autoSave() end
	if input.KeyCode==Enum.KeyCode.F11 then
		if Settings.isFullscreen then applyWindowed() else applyFullscreen() end
	end
	if input.KeyCode==Enum.KeyCode.L then
		if isAnimating then return end
		if MnB.Visible then
			miniDragStart=nil; miniDragging=false
			local bx,by=MnB.AbsolutePosition.X,MnB.AbsolutePosition.Y; MnB.Visible=false
			Main.Size=UDim2.new(0,48,0,48); Main.Position=UDim2.new(0,bx,0,by); Main.BackgroundTransparency=0.3; Main.Visible=true; isAnimating=true
			local t=TweenService:Create(Main,tweenSlow,{Size=UDim2.new(0,NORMAL_SIZE.w,0,NORMAL_SIZE.h),Position=UDim2.new(0,math.max(bx-226,10),0,math.max(by-176,10)),BackgroundTransparency=0})
			t:Play(); t.Completed:Connect(function() isAnimating=false end)
		else
			if Main.Visible then Main.Visible=false; clearParticles() else Main.Visible=true end
		end
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false; sliding=false; miniDragStart=nil; miniDragging=false
		for _,ct in pairs(tabContents) do ct.ScrollingEnabled=true end
