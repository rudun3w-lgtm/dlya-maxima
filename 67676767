local SAVE_DIR  = "RiflisHub"
local SAVE_FILE = "RiflisHub/autosave.json"

local function ensureDir()
	pcall(function()
		if makefolder and not isfolder(SAVE_DIR) then makefolder(SAVE_DIR) end
	end)
end

local function c2t(c) return {R=math.floor(c.R*255),G=math.floor(c.G*255),B=math.floor(c.B*255)} end
local function t2c(t)
	if not t or type(t)~="table" then return nil end
	return Color3.fromRGB(t.R or 0,t.G or 0,t.B or 0)
end

local saveDebounce=false
local function autoSave()
	if saveDebounce then return end
	saveDebounce=true
	task.delay(0.3,function()
		saveDebounce=false
		pcall(function()
			if not writefile then return end
			ensureDir()
			local sd={
				espEnabled=S.espEnabled, namesEnabled=S.namesEnabled,
				tracersEnabled=S.tracersEnabled, rolesEnabled=S.rolesEnabled,
				gunEspEnabled=S.gunEspEnabled, leavesEnabled=S.leavesEnabled,
				snowEnabled=S.snowEnabled, skyEnabled=S.skyEnabled,
				skyColor=c2t(skyColor), skySatVal=skySatVal,
				skyContrastVal=skyContrastVal, skyBrightVal=skyBrightVal,
				rgbSky=rgbSky,
				accentColor=c2t(accentColor), bgColor=c2t(bgColor),
				rgbAccent=rgbAccent, rgbBg=rgbBg, rgbAll=rgbAll,
				aimMurdererEnabled=S.aimMurdererEnabled,
				aimMurdererBtnVisible=S.aimMurdererBtnVisible,
				aimSheriffEnabled=S.aimSheriffEnabled,
				aimSheriffBtnVisible=S.aimSheriffBtnVisible,
				aimInnocentEnabled=S.aimInnocentEnabled,
				aimInnocentBtnVisible=S.aimInnocentBtnVisible,
				aimAllEnabled=S.aimAllEnabled,
				aimAllBtnVisible=S.aimAllBtnVisible,
				stretchRatio=S.stretchRatio, fovValue=S.fovValue,
				grabGunBtnVisible=S.grabGunBtnVisible,
				flingEnabled=S.flingEnabled,
				uiStyle=currentUIStyle, lang=currentLang,
			}
			if toggleRefs.aimMurdererRMB then sd.aimMurdererRMBOn=toggleRefs.aimMurdererRMB.get() end
			if toggleRefs.aimSheriffRMB  then sd.aimSheriffRMBOn=toggleRefs.aimSheriffRMB.get() end
			if toggleRefs.aimInnocentRMB then sd.aimInnocentRMBOn=toggleRefs.aimInnocentRMB.get() end
			if toggleRefs.aimAllRMB      then sd.aimAllRMBOn=toggleRefs.aimAllRMB.get() end
			writefile(SAVE_FILE, HS:JSONEncode(sd))
		end)
	end)
end

local function loadSave()
	local ok,raw=pcall(function()
		if not isfile then error() end
		if not isfile(SAVE_FILE) then error() end
		return readfile(SAVE_FILE)
	end)
	if not ok or not raw or raw=="" then return nil end
	local ok2,d=pcall(function() return HS:JSONDecode(raw) end)
	if not ok2 or type(d)~="table" then return nil end
	return d
end

